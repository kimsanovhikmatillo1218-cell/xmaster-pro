{
  "name": "xmaster-pro",
  "private": true,
  "version": "2.1.0",
  "description": "X-MASTER Pro - Oquv Markaz Boshqaruvi Tizimi",
  "author": {
    "name": "X-MASTER Pro",
    "email": "xmaster@gmail.com"
  },
  "type": "module",
  "homepage": "https://kimsanovhikmatillo1218-cell.github.io/xmaster-pro",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"vite --config vite.electron.config.js\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:build": "vite build --config vite.electron.config.js && electron-builder --win",
    "mobile:build": "vite build --config vite.mobile.config.js",
    "mobile:sync": "npm run mobile:build && npx cap sync",
    "cap:add:android": "npm run mobile:build && npx cap add android",
    "cap:add:ios": "npm run mobile:build && npx cap add ios",
    "cap:sync": "npm run mobile:build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "ios:build": "npm run mobile:build && npx cap sync ios"
  },
  "build": {
    "appId": "uz.xmaster.pro",
    "productName": "X-MASTER Pro",
    "copyright": "Copyright © 2025 X-MASTER Pro",
    "directories": {
      "output": "release",
      "buildResources": "electron"
    },
    "files": [
      "dist-electron/**/*",
      "electron/**/*",
      "!electron/node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "publish": {
      "provider": "github",
      "owner": "kimsanovhikmatillo1218-cell",
      "repo": "xmaster-pro"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "X-MASTER Pro",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wait-on": "^7.2.0"
  }
}
